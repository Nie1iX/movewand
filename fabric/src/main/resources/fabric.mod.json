{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "icon": "${mod_icon}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${mod_license}",
  "contact": {
    "homepage": "https://modrinth.com/project/movewand",
    "issues": "https://github.com/Nie1iX/movewand/issues"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.github.nie1ix.movewand.MoveWand"
    ],
    "client": [
      "io.github.nie1ix.movewand.client.MoveWandClient"
    ]
  },
  "mixins": [
    "movewand.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
